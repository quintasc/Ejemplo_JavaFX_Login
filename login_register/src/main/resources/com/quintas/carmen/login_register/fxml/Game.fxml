<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: lightgrey;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.quintas.carmen.login_register.controller.GameController">
   <children>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 0);">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label text="3 en raya">
               <font>
                  <Font size="32.0" />
               </font>
            </Label>
            <Label fx:id="lblTurno" text="Turno: X" />
            <GridPane fx:id="gridTablero" hgap="5.0" vgap="5.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="80.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="80.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="80.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <Button fx:id="btn00" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Button fx:id="btn01" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Button fx:id="btn02" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <Button fx:id="btn10" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Button fx:id="btn11" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Button fx:id="btn12" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <Button fx:id="btn20" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <Button fx:id="btn21" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Button fx:id="btn22" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onCellClick" prefHeight="80.0" prefWidth="80.0" style="-fx-font-size: 24px;" text=" " GridPane.columnIndex="2" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onReiniciarClick" text="Reiniciar" />
                  <Button mnemonicParsing="false" onAction="#onSalirClick" text="Salir" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
